{
  "manifest_version": 3,
  "name": "Blackjack AI",
  "version": "2.0",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.blackjacksimulator.net/*"],
      "js": ["content.js"],
      "all_frames": false
    }
  ]
}